{
  "name": "@hannd98/mcp-chatops",
  "version": "1.1.1",
  "description": "MCP Server for ChatOps - Tools for querying users, channels, messages, and business automation",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "mcp-chatops": "dist/index.js"
  },
  "files": [
    "dist/",
    "docs/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "esbuild src/index.ts --bundle --platform=node --format=esm --banner:js='#!/usr/bin/env node' --outfile=dist/index.js --packages=external",
    "setup": "tsx src/index.ts",
    "start": "node dist/index.js",
    "bundle": "esbuild src/index.ts --bundle --platform=node --format=esm --packages=external --outfile=dist/index.js",
    "bundle:standalone": "esbuild src/index.ts --bundle --platform=node --format=esm --outfile=dist/index.js --banner:js='#!/usr/bin/env node'",
    "inspect": "npx @modelcontextprotocol/inspector tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "security-check": "bash scripts/security-check.sh",
    "prepublishOnly": "npm run build && npm run security-check"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "mcp",
    "chatops",
    "mattermost",
    "ai",
    "automation",
    "model-context-protocol"
  ],
  "author": "hannd",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nguyendinhhan98/mcp-chatops.git"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.10.2",
    "axios": "^1.7.9",
    "date-fns": "^4.1.0",
    "dotenv": "^16.4.7",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "esbuild": "^0.28.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=20"
  }
}
{
  "manifest_version": 3,
  "name": "ChatOps Helper",
  "version": "1.0.0",
  "description": "Truy cập nhanh ChatOps: tìm kiếm, gửi tin nhắn, kiểm tra mention — trực tiếp từ trình duyệt.",
  "permissions": [
    "storage",
    "activeTab",
    "sidePanel",
    "alarms",
    "cookies",
    "notifications"
  ],
  "host_permissions": [
    "https://chat.runsystem.vn/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://chat.runsystem.vn/*"],
      "css": ["content/content.css"],
      "js": ["content/content.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "ChatOps Helper"
  },
  "side_panel": {
    "default_path": "sidepanel/sidepanel.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["icons/*.png"],
      "matches": ["https://chat.runsystem.vn/*"]
    }
  ]
}

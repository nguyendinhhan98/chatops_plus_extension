# ============================
# ChatOps MCP Server Config
# ============================

# ChatOps Server URL (required)
CHATOPS_URL=https://chat.runsystem.vn

# Authentication - Browser Session (Preferred for ChatOps Fork)
CHATOPS_COOKIE=MMAUTHTOKEN=your_auth_token_here
CHATOPS_CSRF=MMCSRF=your_csrf_token_here

# Authentication - Personal Access Token (Alternative)
CHATOPS_TOKEN=

# Default team name (slug)
CHATOPS_TEAM_NAME=dn
